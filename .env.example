# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Polymarket (Polygon wallet private key — never commit real keys)
POLYMARKET_PRIVATE_KEY=0x...
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# Reddit (create app at https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=prediction-market-bot/1.0

# Twitter/X (optional — scraper works without it but rate-limited)
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# Trading Parameters
BANKROLL_USDC=1000.0
KELLY_FRACTION=0.25
MIN_EDGE=0.05
MIN_CONFIDENCE=0.65
MAX_BET_FRACTION=0.10
MIN_LIQUIDITY_USDC=1000.0
MIN_VOLUME_USDC=500.0
MAX_TIME_TO_RESOLUTION_DAYS=30
MIN_TIME_TO_RESOLUTION_DAYS=1

# Database
DATABASE_URL=sqlite:///./tradetestagent.db

# Model persistence
MODEL_PATH=./ml/xgb_calibrator.joblib
